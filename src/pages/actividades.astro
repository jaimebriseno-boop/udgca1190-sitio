---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const tipoLabel: Record<string, string> = {
  docencia: 'Docencia', edicion: 'Edición', revision: 'Revisión',
  divulgacion: 'Divulgación', evento: 'Evento',
};
const tipoColor: Record<string, string> = {
  docencia: 'green', edicion: 'blue', revision: 'purple', divulgacion: 'teal', evento: 'gray',
};
const actividades = (await getCollection('actividades'))
  .map((e) => e.data)
  .sort((a, b) => String(b.fecha || '').localeCompare(String(a.fecha || '')));
---
<Base titulo="Actividades" descripcion="Docencia, edición, revisión y divulgación del CA UDG-CA-1190.">
  <section class="section">
    <div class="container">
      <div class="pg-head">
        <span class="pg-block" aria-hidden="true"></span>
        <div>
          <p class="kicker">Actividades</p>
          <h1 class="pg-title">Docencia, edición y divulgación</h1>
        </div>
      </div>
      <p class="prose text-muted pg-intro">
        Actividades académicas del Cuerpo Académico: formación de especialistas,
        edición y revisión por pares, y comunicación científica.
      </p>

      <ol class="acts">
        {actividades.map((a) => (
          <li class="act" style={`--act-color: var(--c-${tipoColor[a.tipo] || 'gray'})`}>
            <div class="act__tipo">
              <span class="act__dot" aria-hidden="true"></span>
              <span class="act__tipo-label">{tipoLabel[a.tipo] || a.tipo}</span>
            </div>
            <div class="act__body">
              <h2 class="act__titulo">{a.titulo}</h2>
              {a.descripcion && <p class="act__desc">{a.descripcion}</p>}
              {a.enlace && <a class="act__link" href={a.enlace} target="_blank" rel="noopener">Más información ↗</a>}
            </div>
            {a.fecha && <div class="act__fecha">{a.fecha}</div>}
          </li>
        ))}
      </ol>
    </div>
  </section>
</Base>

<style>
  .pg-head { display: flex; align-items: center; gap: var(--sp-3); }
  .pg-block { width: 16px; height: 48px; background: var(--c-blue); flex: none; }
  .pg-title { font-size: var(--fs-s3); }
  .pg-intro { margin-top: var(--sp-3); }

  .acts { list-style: none; padding: 0; margin-top: var(--sp-6); border-top: 1px solid var(--c-line); }
  .act {
    display: grid; grid-template-columns: 160px 1fr auto; gap: var(--sp-3);
    padding: var(--sp-4) 0; border-bottom: 1px solid var(--c-line);
  }
  .act__tipo { display: flex; align-items: center; gap: var(--sp-1); }
  .act__dot { width: 10px; height: 10px; background: var(--act-color); flex: none; }
  .act__tipo-label { font-family: var(--font-mono); font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: 0.06em; color: var(--act-color); }
  .act__titulo { font-size: var(--fs-s1); font-weight: var(--fw-semibold); line-height: var(--lh-snug); }
  .act__desc { color: var(--c-gray); margin-top: var(--sp-1); font-size: var(--fs-sm); }
  .act__link { font-family: var(--font-mono); font-size: var(--fs-xs); display: inline-block; margin-top: var(--sp-1); }
  .act__fecha { font-family: var(--font-mono); font-size: var(--fs-sm); color: var(--c-gray); }

  @media (max-width: 640px) {
    .act { grid-template-columns: 1fr; gap: var(--sp-1); }
    .act__fecha { grid-row: 1; justify-self: end; }
  }
</style>
