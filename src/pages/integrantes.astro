---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import CardIntegrante from '../components/CardIntegrante.astro';

const lineasCol = await getCollection('lineas');
const lineasMap = Object.fromEntries(lineasCol.map((l) => [l.id, l.data]));

const orden: Record<string, number> = { lider: 0, integrante: 1, colaborador: 2, estudiante: 3 };
const incompleto = (d: any) => (/por completar/i.test(d.bio_corta || '') ? 1 : 0);
const integrantes = (await getCollection('integrantes'))
  .map((e) => e.data)
  // líder primero; perfiles "por completar" al final
  .sort((a, b) => (orden[a.rol] ?? 9) - (orden[b.rol] ?? 9) || incompleto(a) - incompleto(b));
---
<Base titulo="Integrantes" descripcion="Integrantes del Cuerpo Académico UDG-CA-1190.">
  <section class="section">
    <div class="container">
      <div class="pg-head">
        <span class="pg-block" aria-hidden="true"></span>
        <div>
          <p class="kicker">Integrantes</p>
          <h1 class="pg-title">Equipo del Cuerpo Académico</h1>
        </div>
      </div>
      <p class="prose text-muted pg-intro">
        Profesores-investigadores que integran el CA UDG-CA-1190. El liderazgo
        recae en el Dr. Jaime Briseño Ramírez.
      </p>

      <div class="int-grid">
        {integrantes.map((d) => <CardIntegrante data={d} lineasMap={lineasMap} />)}
      </div>
    </div>
  </section>
</Base>

<style>
  .pg-head { display: flex; align-items: center; gap: var(--sp-3); }
  .pg-block { width: 16px; height: 48px; background: var(--c-blue); flex: none; }
  .pg-title { font-size: var(--fs-s3); }
  .pg-intro { margin-top: var(--sp-3); }
  .int-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--sp-3);
    margin-top: var(--sp-6);
  }
</style>
