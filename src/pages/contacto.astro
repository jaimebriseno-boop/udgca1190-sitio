---
import Base from '../layouts/Base.astro';
import { getSitio } from '../lib/datos.mjs';

const sitio = getSitio();
const key = sitio.web3forms_key || '';
const email = sitio.contacto?.email || '';
const ciudad = sitio.contacto?.ciudad || '';
---
<Base titulo="Contacto" descripcion="Contacto del Cuerpo Académico UDG-CA-1190.">
  <section class="section">
    <div class="container">
      <div class="pg-head">
        <span class="pg-block" aria-hidden="true"></span>
        <div>
          <p class="kicker">Contacto</p>
          <h1 class="pg-title">Escríbenos</h1>
        </div>
      </div>

      <div class="contact">
        <div class="contact__form">
          {key ? (
            <form action="https://api.web3forms.com/submit" method="POST">
              <input type="hidden" name="access_key" value={key} />
              <input type="hidden" name="subject" value="Mensaje desde el sitio del CA UDG-CA-1190" />
              <input type="hidden" name="from_name" value="Sitio UDG-CA-1190" />
              {/* honeypot anti-spam */}
              <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" />

              <label class="field">
                <span>Nombre</span>
                <input type="text" name="name" required autocomplete="name" />
              </label>
              <label class="field">
                <span>Correo electrónico</span>
                <input type="email" name="email" required autocomplete="email" />
              </label>
              <label class="field">
                <span>Mensaje</span>
                <textarea name="message" rows="6" required></textarea>
              </label>
              <button class="btn" type="submit">Enviar mensaje</button>
            </form>
          ) : (
            <p class="aviso panel">
              <strong>Formulario pendiente de configurar.</strong> Falta la clave de
              Web3Forms (gratis en <a href="https://web3forms.com" target="_blank" rel="noopener">web3forms.com</a>;
              pégala en <code>data/sitio.yml</code> → <code>web3forms_key</code>).
              Mientras tanto, escribe directamente a
              {email && <> <a href={`mailto:${email}`}>{email}</a></>}.
            </p>
          )}
        </div>

        <aside class="contact__info">
          <p class="kicker">Cuerpo Académico</p>
          <p class="contact__name">UDG-CA-1190</p>
          <p class="contact__sub text-muted">{sitio.adscripcion}</p>
          <hr class="rule" />
          {email && (
            <p class="contact__row">
              <span class="contact__lbl">Correo</span>
              <a href={`mailto:${email}`}>{email}</a>
            </p>
          )}
          {ciudad && (
            <p class="contact__row">
              <span class="contact__lbl">Ubicación</span>
              <span>{ciudad}</span>
            </p>
          )}
        </aside>
      </div>
    </div>
  </section>
</Base>

<style>
  .pg-head { display: flex; align-items: center; gap: var(--sp-3); }
  .pg-block { width: 16px; height: 48px; background: var(--c-blue); flex: none; }
  .pg-title { font-size: var(--fs-s3); }

  .contact { display: grid; grid-template-columns: 1fr; gap: var(--sp-6); margin-top: var(--sp-6); }
  @media (min-width: 820px) { .contact { grid-template-columns: 1.4fr 1fr; gap: var(--sp-8); } }

  .hp { position: absolute; left: -9999px; }
  .field { display: block; margin-bottom: var(--sp-3); }
  .field span { display: block; font-family: var(--font-mono); font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: 0.06em; color: var(--c-gray); margin-bottom: 6px; }
  .field input, .field textarea {
    width: 100%; font: inherit; color: var(--c-ink);
    border: 1px solid var(--c-line); background: var(--c-bg); padding: var(--sp-2);
    border-radius: 0;
  }
  .field input:focus, .field textarea:focus { outline: 2px solid var(--c-teal); outline-offset: 0; border-color: var(--c-teal); }

  .aviso { padding: var(--sp-3) var(--sp-4); font-size: var(--fs-sm); color: var(--c-gray); border-left: 4px solid var(--c-teal); }
  .aviso strong { color: var(--c-ink); }

  .contact__info { border: 1px solid var(--c-line); padding: var(--sp-4); align-self: start; }
  .contact__name { font-size: var(--fs-s2); font-weight: var(--fw-bold); color: var(--c-blue); }
  .contact__sub { font-size: var(--fs-sm); margin-top: 2px; }
  .contact__info .rule { margin: var(--sp-3) 0; }
  .contact__row { display: flex; flex-direction: column; gap: 2px; margin-bottom: var(--sp-2); }
  .contact__lbl { font-family: var(--font-mono); font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: 0.06em; color: var(--c-gray); }
</style>
