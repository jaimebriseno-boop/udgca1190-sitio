---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import CardHerramienta from '../components/CardHerramienta.astro';

const lineas = await getCollection('lineas');
const lineasMap = Object.fromEntries(lineas.map((l) => [l.id, l.data]));

const orden: Record<string, number> = { activa: 0, beta: 1, desarrollo: 2 };
const herramientas = (await getCollection('herramientas'))
  .map((e) => e.data)
  .sort((a, b) => Number(b.destacado) - Number(a.destacado) || (orden[a.estado] ?? 9) - (orden[b.estado] ?? 9));
---
<Base titulo="Herramientas" descripcion="Herramientas estadístico-epidemiológicas y predictivas del CA UDG-CA-1190.">
  <section class="section">
    <div class="container">
      <div class="pg-head">
        <span class="pg-block" aria-hidden="true"></span>
        <div>
          <p class="kicker">Herramientas / Métodos</p>
          <h1 class="pg-title">Herramientas metodológicas</h1>
        </div>
      </div>
      <p class="prose text-muted pg-intro">
        Métodos estadístico-epidemiológicos y predictivos desarrollados por el CA,
        en R y Python, para apoyar la decisión clínica y el análisis poblacional.
      </p>

      <div class="tools-grid">
        {herramientas.map((h) => <CardHerramienta data={h} lineasMap={lineasMap} />)}
      </div>

      <p class="stack-line">
        <span class="kicker">Stack</span>
        <span class="mono">R · Python · Stan / brms · sf · spdep · EpiEstim · Nextflow · tidyverse</span>
      </p>
    </div>
  </section>
</Base>

<style>
  .pg-head { display: flex; align-items: center; gap: var(--sp-3); }
  .pg-block { width: 16px; height: 48px; background: var(--c-blue); flex: none; }
  .pg-title { font-size: var(--fs-s3); }
  .pg-intro { margin-top: var(--sp-3); }
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--sp-3);
    margin-top: var(--sp-6);
  }
  .stack-line { margin-top: var(--sp-6); display: flex; flex-wrap: wrap; gap: var(--sp-2); align-items: baseline; color: var(--c-gray); }
  .stack-line .mono { font-size: var(--fs-sm); }
</style>
