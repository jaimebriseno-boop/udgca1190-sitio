---
import { t, getSitioL } from '../i18n.mjs';
interface Props { lang?: 'es' | 'en' }
const { lang = 'es' } = Astro.props;
const sitio = getSitioL(lang);
const anio = 2026;
---
<footer class="site-footer">
  <div class="site-footer__accent"></div>
  <div class="container site-footer__inner">
    <div class="site-footer__meta">
      <p class="site-footer__name">{t(lang, 'org.name')}</p>
      <p class="site-footer__sub">{sitio.adscripcion}</p>
      <p class="site-footer__legal">
        © {anio} · {sitio.nombre}
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer { background: var(--udg-navy-900); color: #fff; margin-top: var(--sp-16); }
  .site-footer__accent { height: 4px; background: var(--c-gold); }
  .site-footer__inner {
    padding-block: var(--sp-8);
    display: flex;
    justify-content: flex-end;
  }
  .site-footer__meta { text-align: right; }
  .site-footer__legal { margin-left: auto; }
  .site-footer__name { font-weight: var(--fw-semibold); }
  .site-footer__sub { color: var(--udg-navy-300); font-size: var(--fs-sm); }
  .site-footer__legal {
    color: var(--udg-navy-300);
    font-size: var(--fs-xs);
    margin-top: var(--sp-2);
    font-family: var(--font-mono);
    max-width: 52ch;
  }
</style>
