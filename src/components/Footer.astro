---
import { t, getSitioL } from '../i18n.mjs';
interface Props { lang?: 'es' | 'en' }
const { lang = 'es' } = Astro.props;
const sitio = getSitioL(lang);
const anio = 2026;
---
<footer class="site-footer">
  <div class="site-footer__accent"></div>
  <div class="container site-footer__inner">
    <div class="site-footer__plaque">
      <img src="/logos/UDG-CA-1190_logo_horizontal.png" alt="Cuerpo Académico UDG-CA-1190" />
    </div>
    <div class="site-footer__meta">
      <p class="site-footer__name">{t(lang, 'org.name')}</p>
      <p class="site-footer__sub">{sitio.adscripcion}</p>
      <p class="site-footer__legal">
        © {anio} · {sitio.nombre}
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer { background: var(--c-navy); color: #fff; margin-top: var(--sp-16); }
  .site-footer__accent { height: 4px; background: var(--c-gold); }
  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-6);
    align-items: center;
    justify-content: space-between;
    padding-block: var(--sp-8);
  }
  .site-footer__plaque { background: #fff; padding: var(--sp-2) var(--sp-3); display: inline-flex; }
  .site-footer__plaque img { height: 52px; width: auto; display: block; }
  .site-footer__name { font-weight: var(--fw-semibold); }
  .site-footer__sub { color: #c7ccd6; font-size: var(--fs-sm); }
  .site-footer__legal {
    color: #8b93a3;
    font-size: var(--fs-xs);
    margin-top: var(--sp-2);
    font-family: var(--font-mono);
    max-width: 52ch;
  }
</style>
