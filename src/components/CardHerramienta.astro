---
// Tarjeta de herramienta (estilo CEIC plano): tarjeta .card-flat con barra superior
// de color LGAC, glifo de método, pill semántico de estado y tags de tecnología.
import { t } from '../i18n.mjs';
interface Props {
  data: any;
  lineasMap: Record<string, { titulo_corto?: string; titulo: string; color: string }>;
  lang?: 'es' | 'en';
}
const { data: h, lineasMap, lang = 'es' } = Astro.props;
const lg = lineasMap[h.linea];
const estadoPill: Record<string, string> = { activa: 'pill-ok', beta: 'pill-info', desarrollo: 'pill-warn' };
const pillClass = estadoPill[h.estado] || 'pill-warn';
// Enlace interno (página del sitio) abre en la misma pestaña con un CTA destacado;
// los enlaces externos conservan target="_blank".
const appInterno = typeof h.enlace_app === 'string' && h.enlace_app.startsWith('/');
---
<article class="tool card-flat" style={`--tool-color: var(--c-${lg?.color || 'blue'})`}>
  <div class="tool__bar" aria-hidden="true"></div>
  <div class="tool__top">
    <div>
      <p class="tool__kicker">{t(lang, 'tool.tipo.' + h.tipo)}</p>
      <h3 class="tool__name">{h.nombre}</h3>
    </div>
    <svg class="tool__glyph" viewBox="0 0 48 32" aria-hidden="true" fill="none">
      {h.tipo === 'predictiva' && (
        <path d="M2 30 C 12 30, 14 6, 24 6 S 36 30, 46 6" stroke="var(--tool-color)" stroke-width="2" />
      )}
      {h.tipo === 'estadistica' && (
        <g fill="var(--tool-color)">
          <rect x="2" y="18" width="7" height="12" /><rect x="12" y="10" width="7" height="20" />
          <rect x="22" y="4" width="7" height="26" /><rect x="32" y="14" width="7" height="16" />
        </g>
      )}
      {h.tipo === 'pipeline' && (
        <g stroke="var(--tool-color)" stroke-width="2">
          <line x1="6" y1="16" x2="20" y2="16" /><line x1="28" y1="16" x2="42" y2="16" />
          <circle cx="6" cy="16" r="3" fill="var(--tool-color)" /><circle cx="24" cy="16" r="4" fill="none" />
          <circle cx="42" cy="16" r="3" fill="var(--tool-color)" />
        </g>
      )}
    </svg>
  </div>

  <p class="tool__resumen">{h.resumen}</p>

  <div class="tool__tech">
    {h.tecnologias.map((t: string) => <span class="tag">{t}</span>)}
  </div>

  <div class="tool__foot">
    {lg && (
      <span class="badge-linea" style={`--badge-color: var(--c-${lg.color})`}>
        <span class="badge-linea__sq" aria-hidden="true"></span>{lg.titulo_corto || lg.titulo}
      </span>
    )}
    <span class={pillClass}>{t(lang, 'tool.estado.' + h.estado)}</span>
  </div>

  {(h.enlace_app || h.repositorio || h.doi) && (
    <div class="tool__links">
      {h.enlace_app && (appInterno
        ? <a class="tool__link tool__link--cta" href={h.enlace_app}>{t(lang, 'tool.open')}</a>
        : <a class="tool__link" href={h.enlace_app} target="_blank" rel="noopener">{t(lang, 'tool.link_app')}</a>)}
      {h.repositorio && <a class="tool__link" href={h.repositorio} target="_blank" rel="noopener">{t(lang, 'tool.link_repo')}</a>}
      {h.doi && <a class="tool__link" href={`https://doi.org/${h.doi}`} target="_blank" rel="noopener">{t(lang, 'tool.link_doi')}</a>}
    </div>
  )}
</article>

<style>
  .tool {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .tool__bar {
    height: 6px;
    background: var(--tool-color);
    border-radius: 6px 6px 0 0;
    margin: calc(-1 * var(--sp-3)) calc(-1 * var(--sp-3)) var(--sp-1);
  }
  .tool__top { display: flex; align-items: flex-start; justify-content: space-between; gap: var(--sp-2); }
  .tool__kicker { font-family: var(--font-mono); font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: 0.08em; color: var(--tool-color); font-weight: 600; }
  .tool__name { font-size: var(--fs-s1); font-weight: var(--fw-semibold); line-height: var(--lh-snug); margin-top: 2px; }
  .tool__glyph { width: 48px; height: 32px; flex: none; }
  .tool__resumen { color: var(--c-gray); font-size: var(--fs-sm); }
  .tool__tech { display: flex; flex-wrap: wrap; gap: 6px; }
  .tool__foot { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: var(--sp-2); margin-top: var(--sp-1); }
  .tool__links { display: flex; flex-wrap: wrap; gap: var(--sp-3); border-top: 1px solid var(--udg-gray-200); padding-top: var(--sp-2); }
  .tool__link { font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--udg-navy-700); transition: color 150ms ease; }
  .tool__link:hover { color: var(--tool-color); }
  .tool__link--cta { font-weight: var(--fw-semibold); color: var(--tool-color); }
</style>
