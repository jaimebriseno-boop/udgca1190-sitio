---
import { t, getSitioL, localePath } from '../i18n.mjs';
import LangSwitcher from './LangSwitcher.astro';
interface Props { lang?: 'es' | 'en' }
const { lang = 'es' } = Astro.props;
const sitio = getSitioL(lang);
const email = sitio.contacto?.email || '';
const ciudad = sitio.contacto?.ciudad || '';

const items = [
  { href: '/', key: 'nav.home' },
  { href: '/integrantes', key: 'nav.members' },
  { href: '/lineas', key: 'nav.lines' },
  { href: '/produccion', key: 'nav.production' },
  { href: '/herramientas', key: 'nav.tools' },
  { href: '/actividades', key: 'nav.activities' },
  { href: '/contacto', key: 'nav.contact' },
].map((it) => ({ href: localePath(it.href, lang), label: t(lang, it.key) }));

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const home = localePath('/', lang).replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  const h = href.replace(/\/$/, '') || '/';
  return h === home ? path === home : path.startsWith(h);
};
---
<aside id="sidebar">
  <div class="sidebar__inner">
    <a class="sidebar__logo" href={localePath('/', lang)} aria-label={t(lang, 'aria.home')}>
      <img src="/logos/UDG-CA-1190_logo_vertical_reverse.png" alt="Cuerpo Académico UDG-CA-1190" width="250" height="399" />
    </a>
    <p class="sidebar__tag">{sitio.adscripcion}</p>

    <nav class="sidebar__menu" aria-label={t(lang, 'aria.main_nav')}>
      <ul>
        {items.map((it) => (
          <li>
            <a
              href={it.href}
              class:list={[{ 'is-active': isActive(it.href) }]}
              aria-current={isActive(it.href) ? 'page' : undefined}>{it.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="sidebar__contact">
      <p class="kicker">{t(lang, 'nav.contact')}</p>
      {email && <p><a href={`mailto:${email}`}>{email}</a></p>}
      {ciudad && <p class="text-muted">{ciudad}</p>}
      <div class="sidebar__lang"><LangSwitcher lang={lang} variant="sidebar" /></div>
    </div>
  </div>
</aside>

<style>
  .sidebar__lang { margin-top: var(--sp-3); }
</style>
