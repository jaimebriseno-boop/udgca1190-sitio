---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import CardIntegrante from '../CardIntegrante.astro';
import PageHeader from '../PageHeader.astro';
import { t, getSitioL, localize } from '../../i18n.mjs';

interface Props { lang?: 'es' | 'en' }
const { lang = 'es' } = Astro.props;

const lineasCol = await getCollection('lineas');
const lineasMap = Object.fromEntries(lineasCol.map((l) => [l.id, localize('lineas', l.id, l.data, lang)]));

const orden: Record<string, number> = { lider: 0, integrante: 1, colaborador: 2, estudiante: 3 };
const incompleto = (d: any) => (/por completar/i.test(d.bio_corta || '') ? 1 : 0);
const integrantes = (await getCollection('integrantes'))
  .map((e) => localize('integrantes', e.id, e.data, lang))
  // líder primero; perfiles "por completar" al final
  .sort((a, b) => (orden[a.rol] ?? 9) - (orden[b.rol] ?? 9) || incompleto(a) - incompleto(b));

const intro = getSitioL(lang).page_intros?.members || '';
---
<Base titulo={t(lang, 'nav.members')} descripcion={t(lang, 'meta.members')} lang={lang}>
  <PageHeader
    eyebrow={t(lang, 'members.kicker')}
    title={t(lang, 'members.title')}
    description={intro}
    variant="red" />
  <section class="section section--int">
    <div class="container">
      <div class="int-grid">
        {integrantes.map((d) => <CardIntegrante data={d} lineasMap={lineasMap} lang={lang} />)}
      </div>
    </div>
  </section>
</Base>

<style>
  .section--int { padding-block-start: var(--sp-6); }
  .int-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--sp-3);
  }
</style>
