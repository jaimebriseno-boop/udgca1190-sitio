---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getProduccion } from '../../lib/datos.mjs';
import { t, localize } from '../../i18n.mjs';

interface Props { lang?: 'es' | 'en' }
const { lang = 'es' } = Astro.props;

const lineas = (await getCollection('lineas'))
  .map((l) => ({ id: l.id, data: localize('lineas', l.id, l.data, lang) }))
  .sort((a, b) => (a.data.orden ?? 99) - (b.data.orden ?? 99));
const lgacMap: Record<string, any> = {};
const espMap: Record<string, string> = {};
for (const l of lineas) {
  lgacMap[l.id] = { titulo_corto: l.data.titulo_corto, color: l.data.color };
  for (const e of l.data.especificas || []) espMap[e.id] = e.titulo;
}

const integrantes = await getCollection('integrantes');
const nombreMap = Object.fromEntries(integrantes.map((e) => [e.id, e.data.nombre]));
const APELLIDOS: Record<string, string> = {
  'briseno-ramirez': 'Briseño-Ramírez',
  'de-arcos-jimenez': 'De Arcos-Jiménez',
  'vega-cornejo': 'Vega-Cornejo',
  'fernandez-diaz': 'Fernández-Díaz',
  'rodriguez-montano': 'Rodríguez-Montaño',
  'damian-negrete': 'Damián-Negrete',
  'rosales-chavez': 'Rosales-Chávez',
};
const apellido = (id: string) => APELLIDOS[id] || (nombreMap[id] || '').replace(/^\S+\s+/, '');

const enPrepRank = (p: any) => (p.estado === 'en-preparacion' ? 0 : 1);
const produccion = getProduccion()
  .slice()
  .sort((a, b) => enPrepRank(a) - enPrepRank(b) || (parseInt(b.anio) || 0) - (parseInt(a.anio) || 0));

const nPorLgac: Record<string, number> = {};
for (const p of produccion) for (const lg of p.lgac) nPorLgac[lg] = (nPorLgac[lg] || 0) + 1;
const total = produccion.length;
const publicadas = produccion.filter((p) => p.estado !== 'en-preparacion').length;
const enPrep = total - publicadas;
const introMid = t(lang, 'prod.intro_mid', { total, pub: publicadas, prep: enPrep, s: enPrep === 1 ? '' : 's' });
---
<Base titulo={t(lang, 'nav.production')} descripcion={t(lang, 'meta.production')} lang={lang}>
  <section class="section">
    <div class="container">
      <div class="pg-head">
        <span class="pg-block" aria-hidden="true"></span>
        <div>
          <p class="kicker">{t(lang, 'prod.kicker')}</p>
          <h1 class="pg-title">{t(lang, 'prod.title')}</h1>
        </div>
      </div>
      <p class="prose text-muted pg-intro">
        <strong id="pub-count">{total}</strong> <Fragment set:html={introMid} />
      </p>

      <div class="filtros" role="group" aria-label={t(lang, 'aria.filter_lgac')}>
        <button class="filtro is-active" data-filter="all">{t(lang, 'prod.filter_all')} <span>{total}</span></button>
        {lineas.map((l) => (
          <button class="filtro" data-filter={l.id} style={`--f: var(--c-${l.data.color})`}>
            <span class="filtro__sq" aria-hidden="true"></span>{l.data.titulo_corto} <span>{nPorLgac[l.id] || 0}</span>
          </button>
        ))}
      </div>

      <ol class="pubs">
        {produccion.map((p) => (
            <li class="pub" data-lgac={p.lgac.join(' ')}>
              <div class="pub__year">{p.anio}</div>
              <div class="pub__main">
                <p class="pub__titulo">{p.titulo}</p>
                <p class="pub__meta">
                  {p.revista && <span class="pub__revista">{p.revista}</span>}
                  {p.miembros?.length > 0 && (
                    <span class="pub__autores">
                      {p.miembros.map((id: string) => apellido(id)).filter(Boolean).join(' · ')}
                    </span>
                  )}
                </p>
                <div class="pub__badges">
                  {p.estado === 'en-preparacion' && (
                    <span class="tag tag--fill" style="--tag-color: var(--c-teal)">{t(lang, 'prod.en_prep')}</span>
                  )}
                  {p.lgac.map((lid: string) => {
                    const lg = lgacMap[lid] || {};
                    return (
                      <span class="badge-linea" style={`--badge-color: var(--c-${lg.color || 'gray'})`}>
                        <span class="badge-linea__sq" aria-hidden="true"></span>{lg.titulo_corto || lid}
                      </span>
                    );
                  })}
                  <span class="tag">{espMap[p.linea_especifica] || p.linea_especifica}</span>
                  {p.doi && (
                    <a class="pub__doi" href={`https://doi.org/${p.doi}`} target="_blank" rel="noopener">doi:{p.doi} ↗</a>
                  )}
                </div>
              </div>
            </li>
        ))}
      </ol>
    </div>
  </section>
</Base>

<style>
  .pg-head { display: flex; align-items: center; gap: var(--sp-3); }
  .pg-block { width: 16px; height: 48px; background: var(--c-blue); flex: none; }
  .pg-title { font-size: var(--fs-s3); }
  .pg-intro { margin-top: var(--sp-3); }

  .filtros { display: flex; flex-wrap: wrap; gap: var(--sp-1); margin-top: var(--sp-4); }
  .filtro {
    font-family: var(--font-mono); font-size: var(--fs-xs); letter-spacing: 0.03em;
    background: var(--c-bg); border: 1px solid var(--c-line); color: var(--c-ink);
    padding: 6px 10px; cursor: pointer; display: inline-flex; align-items: center; gap: 6px;
  }
  .filtro__sq { width: 10px; height: 10px; background: var(--f, var(--c-gray)); flex: none; }
  .filtro span { color: var(--c-gray); }
  .filtro:hover { border-color: var(--f, var(--c-ink)); }
  .filtro.is-active { background: var(--f, var(--c-ink)); color: #fff; border-color: transparent; }
  .filtro.is-active span { color: rgba(255,255,255,0.85); }
  .filtro.is-active .filtro__sq { background: #fff; }

  .pubs { list-style: none; padding: 0; margin-top: var(--sp-6); border-top: 1px solid var(--c-line); }
  .pub {
    display: grid; grid-template-columns: 64px 1fr; gap: var(--sp-3);
    padding: var(--sp-3) 0; border-bottom: 1px solid var(--c-line);
  }
  .pub[hidden] { display: none; }
  .pub__year { font-family: var(--font-mono); font-size: var(--fs-sm); color: var(--c-gray); font-variant-numeric: tabular-nums; }
  .pub__titulo { font-weight: var(--fw-medium); line-height: var(--lh-snug); }
  .pub__meta { margin-top: 4px; font-size: var(--fs-sm); color: var(--c-gray); display: flex; flex-wrap: wrap; gap: 6px 12px; }
  .pub__revista { font-style: italic; }
  .pub__autores { font-family: var(--font-mono); font-size: var(--fs-xs); }
  .pub__badges { margin-top: var(--sp-2); display: flex; flex-wrap: wrap; gap: var(--sp-2); align-items: center; }
  .pub__doi { font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--c-blue); }

  @media (max-width: 560px) { .pub { grid-template-columns: 1fr; gap: var(--sp-1); } }
</style>

<script>
  const chips = document.querySelectorAll('.filtro');
  const rows = document.querySelectorAll('.pub');
  const counter = document.getElementById('pub-count');
  function apply(f) {
    let shown = 0;
    rows.forEach((r) => {
      const vis = f === 'all' || r.dataset.lgac.split(' ').includes(f);
      r.hidden = !vis;
      if (vis) shown++;
    });
    if (counter) counter.textContent = String(shown);
    chips.forEach((c) => c.classList.toggle('is-active', c.dataset.filter === f));
  }
  chips.forEach((c) => c.addEventListener('click', () => apply(c.dataset.filter)));
</script>
