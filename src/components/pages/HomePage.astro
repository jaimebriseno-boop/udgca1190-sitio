---
import Home from '../../layouts/Home.astro';
import LangSwitcher from '../LangSwitcher.astro';
import { Picture, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import logoReverse from '../../assets/logos/UDG-CA-1190_logo_horizontal_reverse.png';
import { t, getSitioL, localePath } from '../../i18n.mjs';

interface Props { lang?: 'es' | 'en' }
const { lang = 'es' } = Astro.props;

const sitio = getSitioL(lang);
const bgPaths: string[] = (Array.isArray(sitio.home_bgs) && sitio.home_bgs.length)
  ? sitio.home_bgs
  : (sitio.home_bg ? [sitio.home_bg] : []);

// data/sitio.yml guarda rutas tipo "/fondo/x.jpg"; se resuelven por basename
// contra los originales en src/assets/fondo (optimizados por astro:assets).
const fondoGlob = import.meta.glob<ImageMetadata>('../../assets/fondo/*.jpg', {
  eager: true,
  import: 'default',
});
const fondoPorNombre = new Map(
  Object.entries(fondoGlob).map(([ruta, img]) => [ruta.split('/').pop() ?? '', img])
);
const bgs: ImageMetadata[] = bgPaths
  .map((p) => fondoPorNombre.get(p.split('/').pop() ?? ''))
  .filter((img): img is ImageMetadata => Boolean(img));

const SLIDE_WIDTHS = [768, 1280, 1920, 2200];
const SLIDE_SIZES = '100vw';
const SLIDE_QUALITY = 55;

// Preload del primer slide (mismos parámetros, AVIF) para acelerar el LCP.
let preload: { src: string; srcset: string; sizes: string } | undefined;
if (bgs.length > 0) {
  const primero = await getImage({
    src: bgs[0],
    widths: SLIDE_WIDTHS,
    format: 'avif',
    quality: SLIDE_QUALITY,
  });
  preload = { src: primero.src, srcset: primero.srcSet.attribute, sizes: SLIDE_SIZES };
}

const stats = (sitio.kpis || []).map((k: any) => `${k.num} ${k.label}`).join('   ·   ');
const nav: [string, string][] = [
  [localePath('/lineas', lang), t(lang, 'navshort.lines')],
  [localePath('/produccion', lang), t(lang, 'navshort.production')],
  [localePath('/integrantes', lang), t(lang, 'navshort.members')],
  [localePath('/herramientas', lang), t(lang, 'navshort.tools')],
  [localePath('/contacto', lang), t(lang, 'navshort.contact')],
];
const homeTitle = lang === 'en' ? 'UDG-CA-1190 · Research Group' : 'UDG-CA-1190 · Cuerpo Académico';
---
<Home titulo={homeTitle} descripcion={sitio.mision} lang={lang} preload={preload}>
  <section id="dimension">
    <div class="dim__slides" aria-hidden="true">
      {bgs.length > 0 ? (
        bgs.map((img, i) => (
          <div class:list={['dim__slide', { 'is-active': i === 0 }]}>
            <Picture
              src={img}
              widths={SLIDE_WIDTHS}
              sizes={SLIDE_SIZES}
              formats={['avif']}
              fallbackFormat="jpg"
              quality={SLIDE_QUALITY}
              alt=""
              loading={i === 0 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : 'low'}
              decoding="async"
            />
          </div>
        ))
      ) : (
        <div class="dim__deco">
          <svg viewBox="0 0 1200 600" preserveAspectRatio="none">
            <g stroke="#ffffff" stroke-opacity="0.5" stroke-width="1">
              <line x1="0" y1="150" x2="1200" y2="150" />
              <line x1="0" y1="300" x2="1200" y2="300" />
              <line x1="0" y1="450" x2="1200" y2="450" />
            </g>
            <polyline fill="none" stroke="#9fd0e0" stroke-width="3"
              points="0,490 150,430 300,450 450,300 600,330 750,180 900,250 1050,120 1200,180" />
          </svg>
        </div>
      )}
    </div>

    <div class="dim__overlay"></div>

    <div class="dim__lang"><LangSwitcher lang={lang} variant="hero" /></div>

    <div class="dim__content">
      <h1 class="sr-only">{sitio.nombre}</h1>
      <Picture
        class="dim__logo"
        src={logoReverse}
        widths={[720, 1440]}
        sizes="(max-width: 782px) 92vw, 720px"
        formats={['avif', 'webp']}
        fallbackFormat="png"
        alt={`Cuerpo Académico UDG-CA-1190 — ${sitio.nombre}`}
        loading="eager"
      />
      <p class="dim__kicker">{sitio.adscripcion}</p>
      <p class="dim__lead">{sitio.mision}</p>
      <nav class="dim__nav" aria-label={t(lang, 'aria.sections')}>
        {nav.map(([href, label]) => <a href={href}>{label}</a>)}
      </nav>
      <p class="dim__stats">{stats}</p>
    </div>

    <p class="dim__foot">{sitio.adscripcion}</p>

    <button
      type="button"
      class="dim__playpause"
      aria-pressed="false"
      aria-label={t(lang, 'hero.pause')}
      data-label-pause={t(lang, 'hero.pause')}
      data-label-play={t(lang, 'hero.play')}
      hidden
    >
      <svg class="ico-pause" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
        <path d="M3.5 2h3.2v12H3.5zM9.3 2h3.2v12H9.3z" />
      </svg>
      <svg class="ico-play" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
        <path d="M4.5 2.2 13.5 8l-9 5.8z" />
      </svg>
    </button>
  </section>
</Home>

<style>
  .dim__lang {
    position: absolute;
    top: clamp(1rem, 3vw, 2rem);
    right: clamp(1rem, 4vw, 3rem);
    z-index: 4;
  }
</style>

<script>
  // Slideshow de la portada: crossfade entre figuras, con pausa accesible.
  const slides = Array.from(document.querySelectorAll<HTMLElement>('.dim__slide'));
  const boton = document.querySelector<HTMLButtonElement>('.dim__playpause');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (slides.length > 1 && !reduce) {
    let i = 0;
    let timer: ReturnType<typeof setInterval> | null = null;
    let pausaManual = false;

    const avanzar = async () => {
      const siguiente = (i + 1) % slides.length;
      const img = slides[siguiente].querySelector('img');
      if (img) {
        try { await img.decode(); } catch { /* se muestra aunque falle el decode */ }
      }
      slides[i].classList.remove('is-active');
      i = siguiente;
      slides[i].classList.add('is-active');
    };
    const iniciar = () => { if (timer === null) timer = setInterval(avanzar, 6500); };
    const detener = () => { if (timer !== null) { clearInterval(timer); timer = null; } };

    iniciar();

    if (boton) {
      boton.hidden = false;
      boton.addEventListener('click', () => {
        pausaManual = !pausaManual;
        boton.setAttribute('aria-pressed', String(pausaManual));
        const label = pausaManual ? boton.dataset.labelPlay : boton.dataset.labelPause;
        if (label) boton.setAttribute('aria-label', label);
        if (pausaManual) detener();
        else iniciar();
      });
    }

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) detener();
      else if (!pausaManual) iniciar();
    });
  }
</script>
