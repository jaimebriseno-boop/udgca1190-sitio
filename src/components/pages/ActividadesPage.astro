---
import Base from '../../layouts/Base.astro';
import PageHeader from '../PageHeader.astro';
import { getCollection } from 'astro:content';
import { t, getSitioL, localize } from '../../i18n.mjs';

interface Props { lang?: 'es' | 'en' }
const { lang = 'es' } = Astro.props;

const tipoColor: Record<string, string> = {
  docencia: 'green', edicion: 'blue', revision: 'purple', divulgacion: 'teal', evento: 'gray',
};
const actividades = (await getCollection('actividades'))
  .map((e) => localize('actividades', e.id, e.data, lang))
  .sort((a, b) => String(b.fecha || '').localeCompare(String(a.fecha || '')));

const intro = getSitioL(lang).page_intros?.activities || '';
---
<Base titulo={t(lang, 'nav.activities')} descripcion={t(lang, 'meta.activities')} lang={lang}>
  <PageHeader
    eyebrow={t(lang, 'acts.kicker')}
    title={t(lang, 'acts.title')}
    description={intro}
  />
  <section class="section">
    <div class="container">
      <ol class="acts">
        {actividades.map((a) => (
          <li class="act" style={`--act-color: var(--c-${tipoColor[a.tipo] || 'gray'})`}>
            <div class="act__tipo">
              <span class="act__dot" aria-hidden="true"></span>
              <span class="act__tipo-label">{t(lang, 'acts.tipo.' + a.tipo)}</span>
            </div>
            <div class="act__body">
              <h2 class="act__titulo">{a.titulo}</h2>
              {a.descripcion && <p class="act__desc">{a.descripcion}</p>}
              {a.enlace && <a class="act__link" href={a.enlace} target="_blank" rel="noopener">{t(lang, 'acts.more')}</a>}
            </div>
            {a.fecha && <div class="act__fecha">{a.fecha}</div>}
          </li>
        ))}
      </ol>
    </div>
  </section>
</Base>

<style>
  .section { padding-block-start: var(--sp-6); }

  .acts { list-style: none; padding: 0; margin: 0; }
  .act {
    display: grid; grid-template-columns: 160px 1fr auto; gap: var(--sp-3);
    padding: var(--sp-4) var(--sp-2); margin-inline: calc(-1 * var(--sp-2));
    border-bottom: 1px solid var(--udg-gray-200);
    transition: background-color 150ms ease;
  }
  .act:first-child { border-top: 1px solid var(--udg-gray-200); }
  .act:hover { background: var(--udg-gray-50); }
  .act__tipo { display: flex; align-items: center; gap: var(--sp-1); }
  .act__dot { width: 10px; height: 10px; background: var(--act-color); flex: none; }
  .act__tipo-label { font-family: var(--font-mono); font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: 0.06em; color: var(--act-color); }
  .act__titulo { font-size: var(--fs-s1); font-weight: var(--fw-semibold); line-height: var(--lh-snug); }
  .act__desc { color: var(--c-gray); margin-top: var(--sp-1); font-size: var(--fs-sm); }
  .act__link { font-family: var(--font-mono); font-size: var(--fs-xs); display: inline-block; margin-top: var(--sp-1); }
  .act__fecha { font-family: var(--font-mono); font-size: var(--fs-sm); color: var(--udg-gray-700); }

  @media (max-width: 640px) {
    .act { grid-template-columns: 1fr; gap: var(--sp-1); }
    .act__fecha { grid-row: 1; justify-self: end; }
  }
</style>
