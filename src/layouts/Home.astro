---
// Layout de la portada (pantalla completa, estilo Dimension). Sin barra lateral.
import '@fontsource-variable/inter';
import '@fontsource-variable/source-serif-4';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/base.css';
import '../styles/dimension.css';

interface Props { titulo?: string; descripcion?: string }
const { titulo = 'UDG-CA-1190 · Cuerpo Académico', descripcion = '' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og/og-default.jpg', Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ResearchOrganization',
  name: 'Cuerpo Académico UDG-CA-1190 — Investigación Integrativa de Factores Biológicos del Proceso Salud-Enfermedad',
  alternateName: 'UDG-CA-1190',
  url: 'https://udgca1190.com.mx',
  logo: ogImage,
  parentOrganization: { '@type': 'CollegeOrUniversity', name: 'Universidad de Guadalajara', url: 'https://www.udg.mx' },
  areaServed: 'MX',
};
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{titulo}</title>
    {descripcion && <meta name="description" content={descripcion} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#11161f" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Cuerpo Académico UDG-CA-1190" />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={titulo} />
    {descripcion && <meta property="og:description" content={descripcion} />}
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titulo} />
    {descripcion && <meta name="twitter:description" content={descripcion} />}
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="home">
    <slot />
  </body>
</html>
