---
// Layout de la portada (pantalla completa, estilo Dimension). Sin barra lateral.
import '@fontsource-variable/inter';
import '@fontsource-variable/source-serif-4';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/base.css';
import '../styles/dimension.css';
import { altPaths } from '../i18n.mjs';

interface Props {
  titulo?: string;
  descripcion?: string;
  lang?: 'es' | 'en';
  /** Imagen del primer slide (AVIF) para precargar y mejorar el LCP. */
  preload?: { src: string; srcset: string; sizes: string };
}
const { titulo = 'UDG-CA-1190 · Cuerpo Académico', descripcion = '', lang = 'es', preload } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og/og-default.jpg', Astro.site).href;
const alt = altPaths(Astro.url.pathname);
const esUrl = new URL(alt.es, Astro.site).href;
const enUrl = new URL(alt.en, Astro.site).href;
const ogLocale = lang === 'en' ? 'en_US' : 'es_MX';
const ogLocaleAlt = lang === 'en' ? 'es_MX' : 'en_US';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ResearchOrganization',
  name: 'Cuerpo Académico UDG-CA-1190 — Investigación Integrativa de Factores Biológicos del Proceso Salud-Enfermedad',
  alternateName: 'UDG-CA-1190',
  url: 'https://udgca1190.com.mx',
  logo: ogImage,
  parentOrganization: { '@type': 'CollegeOrUniversity', name: 'Universidad de Guadalajara', url: 'https://www.udg.mx' },
  areaServed: 'MX',
};
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{titulo}</title>
    {descripcion && <meta name="description" content={descripcion} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#11161f" />
    <link rel="canonical" href={canonical} />
    {preload && (
      <link
        rel="preload"
        as="image"
        type="image/avif"
        imagesrcset={preload.srcset}
        imagesizes={preload.sizes}
        fetchpriority="high"
      />
    )}
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={esUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Cuerpo Académico UDG-CA-1190" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={titulo} />
    {descripcion && <meta property="og:description" content={descripcion} />}
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titulo} />
    {descripcion && <meta name="twitter:description" content={descripcion} />}
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="home">
    <slot />
  </body>
</html>
