---
// Layout de páginas internas: barra lateral fija (estilo Editorial) + contenido.
import '@fontsource-variable/inter';
import '@fontsource-variable/source-serif-4';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/base.css';
import '../styles/grid.css';
import '../styles/editorial.css';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import { t, altPaths } from '../i18n.mjs';

interface Props { titulo?: string; descripcion?: string; lang?: 'es' | 'en' }
const { titulo = 'UDG-CA-1190', descripcion = '', lang = 'es' } = Astro.props;
const tituloPagina = titulo === 'UDG-CA-1190'
  ? 'UDG-CA-1190 · Cuerpo Académico'
  : `${titulo} · UDG-CA-1190`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og/og-default.jpg', Astro.site).href;
const alt = altPaths(Astro.url.pathname);
const esUrl = new URL(alt.es, Astro.site).href;
const enUrl = new URL(alt.en, Astro.site).href;
const ogLocale = lang === 'en' ? 'en_US' : 'es_MX';
const ogLocaleAlt = lang === 'en' ? 'es_MX' : 'en_US';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ResearchOrganization',
  name: 'Cuerpo Académico UDG-CA-1190 — Investigación Integrativa de Factores Biológicos del Proceso Salud-Enfermedad',
  alternateName: 'UDG-CA-1190',
  url: 'https://udgca1190.com.mx',
  logo: ogImage,
  parentOrganization: { '@type': 'CollegeOrUniversity', name: 'Universidad de Guadalajara', url: 'https://www.udg.mx' },
  areaServed: 'MX',
};
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{tituloPagina}</title>
    {descripcion && <meta name="description" content={descripcion} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#27334F" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={esUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Cuerpo Académico UDG-CA-1190" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={tituloPagina} />
    {descripcion && <meta property="og:description" content={descripcion} />}
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={tituloPagina} />
    {descripcion && <meta name="twitter:description" content={descripcion} />}
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a class="skip-link" href="#main">{t(lang, 'skip')}</a>
    <button class="nav-toggle" id="navToggle" aria-label={t(lang, 'aria.open_menu')} aria-expanded="false">☰</button>
    <div id="navOverlay"></div>
    <div id="wrapper">
      <Sidebar lang={lang} />
      <main id="main">
        <slot />
        <Footer lang={lang} />
      </main>
    </div>
    <script>
      const tg = document.getElementById('navToggle');
      const ov = document.getElementById('navOverlay');
      const close = () => { document.body.classList.remove('nav-open'); tg?.setAttribute('aria-expanded', 'false'); };
      tg?.addEventListener('click', () => {
        const open = document.body.classList.toggle('nav-open');
        tg.setAttribute('aria-expanded', String(open));
      });
      ov?.addEventListener('click', close);
      document.querySelectorAll('#sidebar a').forEach((a) => a.addEventListener('click', close));
    </script>
  </body>
</html>
